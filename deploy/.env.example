# Copy to .env and fill in. Never commit the real .env.

# ── API (Flask signaling) ────────────────────────────────────────────────
FIL_ASYNC_MODE=eventlet
# Long random string; salts the per-network default room name.
FIL_SECRET=change-me-to-a-long-random-string
# The Cloudflare Pages origin(s) allowed to call the API (comma-separated).
# Use your Pages URL and any custom domain.
FIL_CORS_ORIGINS=https://filament.pages.dev
# TURN credential secret — MUST be the same value coturn uses (injected below).
FIL_TURN_SECRET=change-me-another-long-random-string
# Your TURN URLs (UDP + a TCP fallback). Point at turn.<your-domain>.
FIL_TURN_HOST=turn:turn.example.com:3478,turn:turn.example.com:3478?transport=tcp
FIL_TURN_TTL=3600

# ── Caddy (TLS reverse proxy for the API) ────────────────────────────────
API_DOMAIN=api.filament.example.com

# ── coturn ───────────────────────────────────────────────────────────────
TURN_REALM=turn.example.com
# The droplet's PUBLIC IP (coturn advertises this as the relay address).
DROPLET_IP=203.0.113.10
