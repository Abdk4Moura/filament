# Homebrew formula for the filament CLI — lives in Abdk4Moura/homebrew-tap.
# Regenerated per release by packaging/release-followup.sh.
class Filament < Formula
  desc "P2P file transfer between terminals and browsers - no upload, no account"
  homepage "https://filament.autumated.com"
  version "@VERSION@"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/Abdk4Moura/filament/releases/download/cli-v@VERSION@/filament-aarch64-apple-darwin.tar.gz"
      sha256 "@SHA_MAC_ARM@"
    else
      url "https://github.com/Abdk4Moura/filament/releases/download/cli-v@VERSION@/filament-x86_64-apple-darwin.tar.gz"
      sha256 "@SHA_MAC_X64@"
    end
  end

  on_linux do
    url "https://github.com/Abdk4Moura/filament/releases/download/cli-v@VERSION@/filament-x86_64-unknown-linux-musl.tar.gz"
    sha256 "@SHA_LINUX@"
  end

  def install
    bin.install "filament"
    generate_completions_from_executable(bin/"filament", "completions")
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/filament --version")
  end
end
