# Copy to .env and fill in the SECRETS + the tunnel token. Never commit .env.
# Domains/IP are pre-filled for autumated.com on this droplet.

# ── API (Flask signaling) ────────────────────────────────────────────────
FIL_ASYNC_MODE=eventlet
# Long random string; salts the per-network default room name. (openssl rand -hex 32)
FIL_SECRET=change-me-to-a-long-random-string
# The Cloudflare Pages origin(s) allowed to call the API (comma-separated).
FIL_CORS_ORIGINS=https://filament.autumated.com
# Shared room registry + Socket.IO message queue → lets api replicas scale.
FIL_REDIS_URL=redis://redis:6379/0

# ── Cloudflare Tunnel (exposes the API; no open ports) ───────────────────
# Create a tunnel in Cloudflare Zero Trust → Networks → Tunnels, add a Public
# Hostname  api.filament.autumated.com → http://api:8000, then paste its token.
CF_TUNNEL_TOKEN=paste-the-cloudflared-tunnel-token-here

# ── TURN (self-hosted coturn) ────────────────────────────────────────────
# TURN credential secret — shared with coturn automatically via compose. (openssl rand -hex 32)
FIL_TURN_SECRET=change-me-another-long-random-string
FIL_TURN_HOST=turn:turn.filament.autumated.com:3478,turn:turn.filament.autumated.com:3478?transport=tcp
FIL_TURN_TTL=3600
TURN_REALM=turn.filament.autumated.com
# This droplet's public IP (coturn advertises it as the relay address).
DROPLET_IP=165.22.207.231

# ── Resource caps (scale a knob, redeploy just api) ──────────────────────
API_MEM=220m
API_CPUS=0.40
REDIS_MEM=96m
REDIS_CPUS=0.20
REDIS_MAXMEM=64mb
CLOUDFLARED_MEM=64m
CLOUDFLARED_CPUS=0.20
COTURN_MEM=96m
COTURN_CPUS=0.50
