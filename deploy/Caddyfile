# Auto-HTTPS reverse proxy for the signaling API.
# {$API_DOMAIN} is read from the environment (.env). Caddy obtains and renews a
# Let's Encrypt cert automatically, and proxies WebSockets transparently — so
# Socket.IO's /socket.io upgrade just works.
#
# NOTE: the API subdomain must be reachable on :80/:443 for the ACME challenge.
# If your DNS is on Cloudflare, set this subdomain to "DNS only" (grey cloud) so
# Caddy can issue the certificate directly.

{$API_DOMAIN} {
	encode zstd gzip
	reverse_proxy api:8000
}
