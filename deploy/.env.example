# Copy to .env and fill in the secrets. Never commit the real .env.
# Domains below are pre-filled for autumated.com — only the SECRETS and
# DROPLET_IP need editing.

# ── API (Flask signaling) ────────────────────────────────────────────────
FIL_ASYNC_MODE=eventlet
# Long random string; salts the per-network default room name. (openssl rand -hex 32)
FIL_SECRET=change-me-to-a-long-random-string
# The Cloudflare Pages origin(s) allowed to call the API (comma-separated).
FIL_CORS_ORIGINS=https://filament.autumated.com
# TURN credential secret — shared with coturn automatically via compose. (openssl rand -hex 32)
FIL_TURN_SECRET=change-me-another-long-random-string
# TURN URLs on its own subdomain (covered by the *.filament.autumated.com wildcard).
FIL_TURN_HOST=turn:turn.filament.autumated.com:3478,turn:turn.filament.autumated.com:3478?transport=tcp
FIL_TURN_TTL=3600

# ── Caddy (TLS reverse proxy for the API) ────────────────────────────────
API_DOMAIN=api.filament.autumated.com

# ── coturn ───────────────────────────────────────────────────────────────
TURN_REALM=turn.filament.autumated.com
# The droplet's PUBLIC IP (coturn advertises this as the relay address).
DROPLET_IP=203.0.113.10
