[0.015191, "o", "\r\n\u001b[1;36m=== UX: grant shell, then 'filament ssh peer -- echo OK' over the data-channel tunnel ===\u001b[0m\r\n"]
[0.06661, "o", "\u001b[2m  topology: B = the box you ssh INTO (acceptor, FILAMENT_L2=1); A = you\u001b[0m\r\n\u001b[1;35m[B]$\u001b[0m FILAMENT_L2=1 filament up    (the box, accepts tunnels)\r\n"]
[0.791312, "o", "\u001b[1;35m[B]$\u001b[0m filament grant laptop shell   (consent: deny-by-default)\r\n"]
[0.798181, "o", "granted 'shell' to 'laptop'. they can now `filament ssh` into this machine (their key is installed on first connect).\r\n"]
[1.304714, "o", "\u001b[1;33m[A]$\u001b[0m filament ssh server -- echo OK\r\n"]
[1.870345, "o", "\u001b[1;33m[A]\u001b[0m remote stdout: OK-OVER-FILAMENT   (attempts: 1)\r\n"]
[1.940349, "o", "\r\n\u001b[1;32m  ✔ PASS\u001b[0m  shell granted; ssh ran a remote command over the tunnel\r\nRESULT 06 PASS shell granted; ssh ran a remote command over the tunnel\r\n"]
[1.941363, "x", "0"]
